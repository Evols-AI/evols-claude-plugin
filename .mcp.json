{
  "mcpServers": {
    "evols": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/plugin/mcp_server/server.py"],
      "env": {
        "EVOLS_API_URL": "${user_config.EVOLS_API_URL}",
        "EVOLS_API_KEY": "${user_config.EVOLS_API_KEY}",
        "EVOLS_PLAN": "${user_config.EVOLS_PLAN}"
      }
    }
  }
}
